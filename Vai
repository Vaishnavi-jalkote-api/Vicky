<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>To My Future Husband ❤️</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:linear-gradient(135deg,#ffe6f0,#fff5f8);
    overflow-x:hidden;
    color:#444;
}

header{
    text-align:center;
    padding:80px 20px;
}

h1{
    color:#e91e63;
    font-size:3rem;
}

.subtitle{
    margin-top:15px;
    font-size:1.2rem;
}

section{
    max-width:900px;
    margin:30px auto;
    padding:30px;
}

.card{
    background:white;
    padding:25px;
    border-radius:20px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
    margin-bottom:25px;
}

.card h2{
    color:#e91e63;
    margin-bottom:15px;
}

ul{
    padding-left:20px;
}

li{
    margin-bottom:10px;
}

#countdown{
    font-size:2rem;
    color:#e91e63;
    text-align:center;
    font-weight:bold;
}

footer{
    text-align:center;
    padding:30px;
    color:#777;
}

.heart{
    position:fixed;
    bottom:-20px;
    color:pink;
    animation:float 8s linear infinite;
    z-index:-1;
}

@keyframes float{
    from{
        transform:translateY(0);
        opacity:1;
    }
    to{
        transform:translateY(-100vh);
        opacity:0;
    }
}

.love-letter{
    line-height:1.8;
}
</style>
</head>
<body>

<header>
    <h1>To My Future Husband ❤️</h1>
    <p class="subtitle">
        A little place on the internet dedicated only to you.
    </p>
</header>

<section>

<div class="card">
    <h2>💕 Welcome</h2>
    <p>
        Dear Husband,
        <br><br>
        Sometimes words are difficult to express face to face.
        So I created this little website to tell you how special
        you are to me.
        <br><br>
        Thank you for coming into my life and making every day brighter.
    </p>
</div>

<div class="card">
    <h2>⏳ Our Wedding Countdown</h2>
    <div id="countdown"></div>
</div>

<div class="card">
    <h2>💖 Reasons Why I Love You</h2>
    <ul>
        <li>You make me feel safe.</li>
        <li>You always support me.</li>
        <li>You make me smile even on difficult days.</li>
        <li>You respect and care for me.</li>
        <li>You are my favorite person.</li>
    </ul>
</div>

<div class="card">
    <h2>🌸 Our Future Dreams</h2>
    <ul>
        <li>Travel together.</li>
        <li>Create beautiful memories.</li>
        <li>Build our dream home.</li>
        <li>Grow old together.</li>
        <li>Always stay best friends.</li>
    </ul>
</div>

<div class="card">
    <h2>💌 A Letter To You</h2>
    <div class="love-letter">
        My Dear,
        <br><br>
        I don't know what the future holds,
        but I know one thing for sure—
        I want to experience it with you.
        <br><br>
        Thank you for being patient, caring,
        and for choosing me as your life partner.
        <br><br>
        Every day I become more excited about
        our journey together.
        <br><br>
        Forever Yours ❤️
    </div>
</div>

</section>

<footer>
    Made with Love ❤️
</footer>

<script>

// Wedding Date
const weddingDate = new Date("YOUR_WEDDING_DATE");

function updateCountdown(){
    const now = new Date();
    const diff = weddingDate - now;

    if(diff <= 0){
        document.getElementById("countdown").innerHTML =
        "🎉 We Are Married!";
        return;
    }

    const days = Math.floor(diff/(1000*60*60*24));

    document.getElementById("countdown").innerHTML =
    days + " Days Left ❤️";
}

setInterval(updateCountdown,1000);
updateCountdown();

// Floating Hearts
function createHeart(){
    const heart = document.createElement("div");
    heart.classList.add("heart");
    heart.innerHTML="❤️";
    heart.style.left=Math.random()*100+"vw";
    heart.style.fontSize=(Math.random()*20+15)+"px";

    document.body.appendChild(heart);

    setTimeout(()=>{
        heart.remove();
    },8000);
}

setInterval(createHeart,500);

</script>

</body>
</html>
